// Shipping Method
$(document).delegate('#button-shipping-method', 'click', function() {
    if (isRegisterCheckoutVisible()) {
        submitRegisterCheckout(function(success) {
            if (success) {
                $('#button-shipping-method').trigger('click');
            } else {
                checkoutShowTopWarning('Спочатку заповніть дані нового покупця.');
                checkoutScrollTo($('[data-step="checkout-option"]'));
            }
        });

        return;
    }

    var $step = $('#collapse-shipping-method');
    var data  = $step.find('input[type="radio"]:checked, input[type="hidden"], input[type="text"], input[type="tel"], select, textarea').serialize();
    $.ajax({
        url: 'index.php?route=checkout/shipping_method/save',
        type: 'post',
        data: data,
        dataType: 'json',
        beforeSend: function() { $('#button-shipping-method').button('loading'); },
        success: function(json) {
            $('.alert-dismissible, .text-danger').remove();

            if (json['redirect']) {
                location = json['redirect'];
            } else if (json['error']) {
                $('#button-shipping-method').button('reset');
                if (json['error']['warning']) {
                    $step.prepend('<div class="alert alert-danger alert-dismissible">' + json['error']['warning'] + '<button type="button" class="close" data-dismiss="alert">&times;</button></div>');
                }
            } else {
                // Update delivery summary in right panel
                var deliveryLabel = $step.find('input[name="np_delivery_type"]:checked').closest('.order__delivery-block').find('.checkbox-block span').first().text().trim();
                var cityName = $step.find('#np_city_name').val() || $step.find('#np_courier_city_name').val() || $step.find('input[name="sc_city"]').val();
                var warehouseName = $step.find('#np_warehouse_name').val() || '';
                var courierStreet = $step.find('input[name="np_street"]').val() || '';
                var courierHouse = $step.find('input[name="np_house"]').val() || '';
                var storeAddress = $step.find('input[name="sc_address"]').val() || '';
                var summary = deliveryLabel;
                if (cityName) summary += ', ' + cityName;
                if (warehouseName) {
                    summary += ' — ' + warehouseName;
                } else if (courierStreet) {
                    summary += ' — ' + courierStreet + (courierHouse ? ', ' + courierHouse : '');
                } else if (storeAddress) {
                    summary += ' — ' + storeAddress;
                }
                if (summary) {
                    $('#order-delivery-summary').text(summary).closest('.order__info-item').show();
                }

                reloadCheckoutDependencies({
                    paymentMethod: true,
                    confirmPending: true
                });
                $('#button-shipping-method').button('reset');
            }
        },
        error: function(xhr, ajaxOptions, thrownError) {
            alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
        }
    });
});

