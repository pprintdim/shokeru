<section class="userData" data-userData="change-number">
    <div class="container">
        <div class="userData__inner">
            <button class="userData__close">
                {{ button_close }}
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none">
                    <rect x="9" y="28.7991" width="28" height="4" transform="rotate(-45 9 28.7991)" fill="#202222"/>
                    <rect x="28.8008" y="31.6274" width="9" height="4" transform="rotate(-135 28.8008 31.6274)" fill="#202222"/>
                    <rect x="11.8281" y="9" width="9" height="4" transform="rotate(45 11.8281 9)" fill="#202222"/>
                </svg>
            </button>
            <div class="userData__info">
                <div class="userData__info-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none">
                        <path d="M21.7147 6.6665H14.2861C13.2757 6.6665 12.3068 7.06786 11.5923 7.78229C10.8779 8.49671 10.4766 9.46568 10.4766 10.476V29.5236C10.4766 30.534 10.8779 31.503 11.5923 32.2174C12.3068 32.9318 13.2757 33.3332 14.2861 33.3332H25.7147C26.725 33.3332 27.694 32.9318 28.4084 32.2174C29.1228 31.503 29.5242 30.534 29.5242 29.5236V15.476M16.1908 29.5236H23.8099" stroke="#202222" stroke-width="2" stroke-linecap="square" stroke-linejoin="round"/>
                        <path d="M29.75 3V11.5425" stroke="#202222" stroke-width="2" stroke-linecap="square" stroke-linejoin="round"/>
                        <path d="M25.5 7.27148H34" stroke="#202222" stroke-width="2" stroke-linecap="square" stroke-linejoin="round"/>
                    </svg>
                </div>
                <div class="userData__info-content">
                    <h2 class="userData__info-title">{{ heading_title }}</h2>
                    <p class="userData__info-descr" id="change-phone-descr">{{ text_descr }}</p>
                </div>
            </div>
            <div class="userData__form-result" id="change-phone-result" style="display:none;"></div>
            <form class="userData__form form-block" id="change-phone-form">
                <div class="userData__form-item">
                    <input class="userData__form-input form-input" type="tel" name="telephone" placeholder="{{ text_new_phone }}*" required>
                </div>
                <div class="userData__form-item userData__form-code" id="change-phone-code-block" style="display:none;">
                    <input class="userData__form-input form-input" type="text" name="code" placeholder="{{ text_sms_code }}*" inputmode="numeric" maxlength="6">
                </div>
                <button class="userData__form-btn btn" type="submit">{{ button_change }}</button>
            </form>
        </div>
    </div>
</section>

<script>
(function () {
    const form      = document.getElementById('change-phone-form');
    if (!form) return;

    const phoneInput = form.querySelector('[name="telephone"]');
    const codeInput  = form.querySelector('[name="code"]');
    const codeBlock  = document.getElementById('change-phone-code-block');
    const descr      = document.getElementById('change-phone-descr');
    const resultEl   = document.getElementById('change-phone-result');

    function showResult(msg, isError) {
        resultEl.textContent = msg;
        resultEl.style.color   = isError ? '#e53935' : '#2e7d32';
        resultEl.style.display = 'block';
    }
    function clearResult() {
        resultEl.textContent   = '';
        resultEl.style.display = 'none';
    }

    form.addEventListener('submit', function (e) {
        e.preventDefault();
        clearResult();

        const phone = phoneInput.value.trim();
        const code  = codeInput.value.trim();

        /* ── 1. немає коду → відправляємо SMS ── */
        if (!code) {
            if (!phone) {
                showResult('{{ error_phone }}', true);
                return;
            }

            fetch('index.php?route=account/change_phone/smsSend', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'telephone=' + encodeURIComponent(phone),
                credentials: 'same-origin'
            })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (data.success) {
                    descr.textContent      = data.success;
                    codeBlock.style.display = 'block';
                    codeInput.focus();
                } else {
                    showResult(data.error || 'Помилка відправки', true);
                }
            })
            .catch(function () { showResult('Помилка мережі', true); });

            return;
        }

        /* ── 2. є код → перевіряємо і змінюємо ── */
        fetch('index.php?route=account/change_phone/verifyCode', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'code=' + encodeURIComponent(code),
            credentials: 'same-origin'
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (data.success) {
                showResult(data.success, false);
                if (data.redirect) {
                    setTimeout(function () { window.location.href = data.redirect; }, 1200);
                }
            } else {
                showResult(data.error || 'Невірний код', true);
            }
        })
        .catch(function () { showResult('Помилка сервера', true); });
    });
})();
</script>
