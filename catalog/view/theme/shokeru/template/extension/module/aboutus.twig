

<section class="aboutus">
    <div class="container">
        <div class="aboutus__inner">
            <div class="aboutus__content">
                {% if content %}
                    {{ content|raw }}
                {% endif %}
            </div>

            {% if stats %}
                <div class="aboutus__block">
                    {% for stat in stats %}
                        {% if stat.value or stat.label %}
                            <p class="aboutus__item">
                                <span>
                                
                                    {{ stat.value }}
                                    {% if stat.suffix %}<span>{{ stat.suffix }}</span>{% endif %}
                                </span>
                                {{ stat.label }}
                                
                            </p>
                        {% endif %}
                    {% endfor %}
                </div>
            {% endif %}

            {% if cards %}
                <div class="aboutus__box">
                    {% for card in cards %}
                        {% if card.title or card.accent %}
                            <div class="aboutus__box-item">
                                <h4 class="aboutus__box-title">
                                    {{ text_rating ?: 'Рейтинг' }}
                                    <span>{{ card.title }}</span>
                                </h4>
                                <div class="aboutus__box-bottom">
                                    <span class="aboutus__box-icons">//////////</span>
                                    <a class="aboutus__box-btn" href="{{ card.link ?: '#' }}">
                                        {% if loop.first %}
                                            <svg xmlns="http://www.w3.org/2000/svg" width="8" height="12" viewBox="0 0 8 12" fill="none">
                                                <path fill-rule="evenodd" clip-rule="evenodd" d="M0.666504 10.0002L4.6665 6.00016L0.666503 2.00016L1.99984 0.666829L7.33317 6.00016L1.99984 11.3335L0.666504 10.0002Z" fill="white"/>
                                            </svg>
                                        {% else %}
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                                                <path fill-rule="evenodd" clip-rule="evenodd" d="M4.6665 12.0002L8.6665 8.00016L4.6665 4.00016L5.99984 2.66683L11.3332 8.00016L5.99984 13.3335L4.6665 12.0002Z" fill="#202222"/>
                                            </svg>
                                        {% endif %}
                                    </a>
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            {% endif %}
        </div>
    </div>
</section>
