<div class="shop__content">
    <form class="shop__filters" action="{{ action }}" method="get">
        <div class="shop__filters-top">
            <button class="shop__filters-open" type="button">{{ text_filter }}</button>

            {# Вибрані фільтри #}
            <div class="shop__filters-selected filters-selected">
                {% for group in filter_groups %}
                    {% for filter in group.filter %}
                        {% if filter.selected %}
                            <div class="filters-selected-item">
                                <p class="filters-selected-title">{{ filter.title }}</p>
                                <button class="filters-selected-delete" type="button" data-filter-id="{{ filter.filter_id }}"></button>
                            </div>
                        {% endif %}
                    {% endfor %}
                {% endfor %}
                {% if price_label %}
                    <div class="filters-selected-item">
                        <p class="filters-selected-title">{{ price_label }}</p>
                        <button class="filters-selected-delete" type="button" data-price-filter="1"></button>
                    </div>
                {% endif %}
            </div>

            {# Сортування #}
            <select class="shop__filters-sort" name="sort_order">
                {% for option in sort_options %}
                    <option value="{{ option.value }}"
                        {% if sort_selected == option.value %}selected{% endif %}>
                        {{ option.text }}
                    </option>
                {% endfor %}
            </select>
        </div>

        <div class="shop__filters-bottom">
            <div class="shop__filters-start">
                <div class="container">
                    <button class="shop__filters-start--reset" type="reset">{{ button_reset_filter }}</button>
                    <p class="shop__filters-start--number">{{ text_filter }} ({{ selected_total|default(0) }})</p>
                </div>
            </div>
            <div class="container">
                <div class="shop__filters-menu">
                    <button class="shop__filters-close" type="button"></button>
                    <select class="shop__filters-sort" name="sort_order_mobile">
                        {% for option in sort_options %}
                            <option value="{{ option.value }}"
                                {% if sort_selected == option.value %}selected{% endif %}>
                                {{ option.text }}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div class="shop__filters-info">
                    {% if filter_groups %}
                        <div class="filters-open-mobile">
                            {% for group in filter_groups %}
                                <button class="filters-open-title" type="button" data-filter-target="{{ group.filter_group_id }}">{{ group.name }}</button>
                            {% endfor %}
                        </div>
                    {% endif %}

                    {# Фільтри по групах #}
                    {% for group in filter_groups %}
                        <div class="shop__filters-box" data-filter-id="{{ group.filter_group_id }}">
                            <div class="shop__filters-block">
                                <h3 class="shop__filters-title">{{ group.name }}</h3>
                                <div class="shop__filters-select">
                                    {% for filter in group.filter %}
                                        <label class="checkbox-block">
                                            <input type="checkbox" name="filter" value="{{ filter.filter_id }}" hidden
                                                {% if filter.selected %}checked{% endif %}>
                                            <span>{{ filter.name }}</span>
                                        </label>
                                    {% endfor %}
                                </div>
                                <div class="shop__filters-end">
                                    <button class="shop__filters-send btn-4" type="submit">{{ button_confirm }}</button>
                                    <button class="shop__filters-resets btn-3" type="button">{{ button_reset_filter }}</button>
                                </div>
                            </div>
                        </div>
                    {% endfor %}

                    {# Ціновий фільтр #}
                    <div class="shop__filters-box">
                        <div class="shop__filters-block">
                            <h3 class="shop__filters-title">{{ text_price_title }}</h3>
                            <div class="shop__filters-price filters-price">
                                <input type="number" name="price_from" value="{{ price_from|default('') }}" min="0" placeholder="{{ text_from }}">
                                <input type="number" name="price_to" value="{{ price_to|default('') }}" min="0" placeholder="{{ text_to }}">
                            </div>
                        </div>
                    </div>
                </div>

                {# Кнопки застосування / скидання #}
                <div class="shop__filters-buttons">
                    <button class="shop__filters-back btn-3" type="button">{{ button_back }}</button>
                    <button class="shop__filters-reset btn-3" type="reset">{{ button_reset }}</button>
                    <button class="shop__filters-submit btn-4" type="submit">{{ button_apply }}</button>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
document.addEventListener("DOMContentLoaded", function () {

    const filterForm = document.querySelector(".shop__filters");
    if (!filterForm) return;

    const baseUrl = document.querySelector('base')?.getAttribute('href') || '';
    const filterBase = {{ filter_base|json_encode|raw }};
    const filterSlugs = {{ filter_slugs|json_encode|raw }};
    const sortSlugs = {{ sort_slugs|json_encode|raw }};

    function buildQuery(params) {
        const query = [];

        params.forEach((value, key) => {
            const encodedKey = encodeURIComponent(key);
            let encodedValue = encodeURIComponent(value);

            if (key === 'route') {
                encodedValue = encodedValue.replace(/%2F/gi, '/');
            }

            query.push(encodedKey + '=' + encodedValue);
        });

        return query.join('&');
    }

    function redirectWithParams(params) {
        const query = buildQuery(params);
        window.location.href = baseUrl + 'index.php' + (query ? '?' + query : '');
    }

    // Відкриття / закриття фільтрів
    const toggleBtn = document.querySelector(".shop__filters-open");
    if (toggleBtn) toggleBtn.addEventListener("click", () => filterForm.classList.toggle("active"));

    const closeBtn = document.querySelector(".shop__filters-close");
    if (closeBtn) closeBtn.addEventListener("click", () => filterForm.classList.remove("active"));

    const backBtn = document.querySelector(".shop__filters-back");
    if (backBtn) backBtn.addEventListener("click", () => filterForm.classList.remove("active"));

    const filterTabButtons = document.querySelectorAll(".filters-open-title[data-filter-target]");
    const filterPanels = document.querySelectorAll(".shop__filters-box[data-filter-id]");

    filterTabButtons.forEach(tabBtn => {
        tabBtn.addEventListener("click", () => {
            const targetId = tabBtn.dataset.filterTarget;

            filterPanels.forEach(panel => {
                if (panel.dataset.filterId === targetId) {
                    panel.classList.add("active");
                } else {
                    panel.classList.remove("active");
                }
            });
        });
    });

    filterPanels.forEach(panel => {
        const title = panel.querySelector(".shop__filters-title");

        if (title) {
            title.addEventListener("click", () => {
                filterPanels.forEach(item => item.classList.remove("active"));
            });
        }
    });

    // Скидання чекбоксів конкретної групи
    document.querySelectorAll(".shop__filters-resets").forEach(btn => {
        btn.addEventListener("click", () => {
            const box = btn.closest(".shop__filters-box");
            if (!box) return;
            box.querySelectorAll('input[type="checkbox"]').forEach(input => input.checked = false);
        });
    });

    // Видалення конкретного фільтра
    document.querySelectorAll(".filters-selected-delete").forEach(btn => {
        btn.addEventListener("click", () => {
            if (btn.dataset.priceFilter) {
                const priceFrom = filterForm.querySelector('input[name="price_from"]');
                const priceTo = filterForm.querySelector('input[name="price_to"]');

                if (priceFrom) priceFrom.value = '';
                if (priceTo) priceTo.value = '';

                submitFilters();
                return;
            }

            const filterId = btn.dataset.filterId;
            document.querySelectorAll(`input[type="checkbox"][value="${filterId}"]`)
                .forEach(cb => cb.checked = false);
            submitFilters();
        });
    });

    // Сортування — одразу застосовуємо
    const sortSelects = document.querySelectorAll('.shop__filters-sort');
    sortSelects.forEach(select => {
        select.addEventListener('change', () => {
            sortSelects.forEach(otherSelect => {
                if (otherSelect !== select) {
                    otherSelect.value = select.value;
                }
            });

            submitFilters();
        });
    });

    // Перехоплюємо ВСІ submit-кнопки форми
    filterForm.addEventListener('submit', function(e) {
        e.preventDefault();
        submitFilters();
    });

    // Кнопка "Скинути" — очищаємо і редіректимо
    const resetButtons = filterForm.querySelectorAll('.shop__filters-reset, .shop__filters-start--reset');
    resetButtons.forEach(resetBtn => {
        resetBtn.addEventListener('click', function(e) {
            e.preventDefault();
            window.location.href = cleanBase();
        });
    });

    // чиста SEO-база (категорія/каталог без фільтрів)
    function cleanBase() {
        return (filterBase || filterForm.getAttribute('action') || window.location.pathname)
            .split('?')[0].replace(/\/+$/, '');
    }

    function submitFilters() {
        let base = cleanBase();

        // вибрані фільтри → слаги у ШЛЯХ (SEO), решта (без слага) → query
        const selected = Array.from(filterForm.querySelectorAll('input[name="filter"]:checked'))
            .map(input => input.value).filter(Boolean);

        let path = '';
        const noSlug = [];
        selected.forEach(id => {
            if (filterSlugs && filterSlugs[id]) { path += '/' + filterSlugs[id]; }
            else { noSlug.push(id); }
        });

        const qs = new URLSearchParams();
        if (noSlug.length) qs.set('filter', noSlug.join(','));

        const searchInput = filterForm.querySelector('input[name="search"]');
        if (searchInput && searchInput.value.trim() !== '') qs.set('search', searchInput.value.trim());

        const priceFrom = filterForm.querySelector('input[name="price_from"]');
        const priceTo   = filterForm.querySelector('input[name="price_to"]');
        if (priceFrom?.value) qs.set('price_from', priceFrom.value);
        if (priceTo?.value)   qs.set('price_to', priceTo.value);

        const sortSelect = filterForm.querySelector('.shop__filters-sort');
        const sortValue = sortSelect?.value;
        if (sortValue) {
            if (sortSlugs && sortSlugs[sortValue]) {
                // SEO: сорт у шлях (/.../popular)
                path += '/' + sortSlugs[sortValue];
            } else {
                const dashIndex = sortValue.lastIndexOf('-');
                if (dashIndex !== -1) {
                    qs.set('sort', sortValue.substring(0, dashIndex));
                    qs.set('order', sortValue.substring(dashIndex + 1));
                } else {
                    qs.set('sort', sortValue);
                }
            }
        }

        const q = qs.toString();
        window.location.href = base + path + (q ? '?' + q : '');
    }
});
</script>
